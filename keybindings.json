// for mac
[
    // 十字キー移動
    {
        "key": "cmd+i",
        "command": "cursorUp",
        "when": "editorTextFocus"
    },
    {
        "key": "cmd+j",
        "command": "cursorLeft",
        "when": "editorTextFocus"
    },
    {
        "key": "cmd+k",
        "command": "cursorDown",
        "when": "editorTextFocus"
    },
    {
        "key": "cmd+l",
        "command": "cursorRight",
        "when": "editorTextFocus"
    },
    // 単語単位で移動
    {
        "key": "cmd+alt+j",
        "command": "cursorWordLeft",
        "when": "editorTextFocus"
    },
    {
        "key": "cmd+alt+l",
        "command": "cursorWordRight",
        "when": "editorTextFocus"
    },
    // // 行頭まで移動
    // {
    //     "key": "alt+a",
    //     "command": "cursorHome",
    //     "when": "editorTextFocus"
    // },
    // // 行末まで移動
    // {
    //     "key": "alt+e",
    //     "command": "cursorEnd",
    //     "when": "editorTextFocus"
    // },
    // 十字キー選択
    {
        "key": "cmd+shift+i",
        "command": "cursorUpSelect",
        "when": "textInputFocus"
    },
    {
        "key": "cmd+shift+j",
        "command": "cursorLeftSelect",
        "when": "textInputFocus"
    },
    {
        "key": "cmd+shift+k",
        "command": "cursorDownSelect",
        "when": "textInputFocus"
    },
    {
        "key": "cmd+shift+l",
        "command": "cursorRightSelect",
        "when": "textInputFocus"
    },
    // 単語単位で選択
    {
        "key": "cmd+shift+alt+j",
        "command": "cursorWordLeftSelect",
        "when": "textInputFocus"
    },
    {
        "key": "cmd+shift+alt+l",
        "command": "cursorWordRightSelect",
        "when": "textInputFocus"
    },
    // 行頭まで選択
    {
        "key": "cmd+shift+a",
        "command": "cursorHomeSelect",
        "when": "editorTextFocus"
    },
    // 行末まで選択
    {
        "key": "cmd+shift+e",
        "command": "cursorEndSelect",
        "when": "editorTextFocus"
    },
    // 行の移動
    {
        "key": "alt+i",
        "command": "editor.action.moveLinesUpAction",
        "when": "editorTextFocus"
    },
    {
        "key": "alt+k",
        "command": "editor.action.moveLinesDownAction",
        "when": "editorTextFocus"
    },
    // 行の削除
    {
        "key": "cmd+shift+alt+k",
        "command": "editor.action.deleteLines",
        "when": "textInputFocus && !editorReadonly"
    },
    // 複製
    {
        "key": "shift+alt+i",
        "command": "editor.action.copyLinesUpAction",
        "when": "editorTextFocus"
    },
    {
        "key": "shift+alt+k",
        "command": "editor.action.copyLinesDownAction",
        "when": "editorTextFocus"
    },
    // マルチカーソル
    {
        "key": "cmd+alt+k",
        "command": "cursorColumnSelectDown",
        "when": "editorTextFocus"
    },
    {
        "key": "cmd+alt+i",
        "command": "cursorColumnSelectUp",
        "when": "editorTextFocus"
    }
]
